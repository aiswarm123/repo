# Telegram bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Telegram chat ID of the support group/channel where tickets are forwarded
# Use a negative number for groups, e.g. -1001234567890
SUPPORT_CHAT_ID=-1001234567890

# Path to the SQLite database file (default: support.db in the working directory)
DATABASE_PATH=support.db
